<Window x:Class="PhoneBookApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PhoneBookApp"
        xmlns:vms="clr-namespace:PhoneBookApp.ViewModels"
        xmlns:views="clr-namespace:PhoneBookApp.Views"
        mc:Ignorable="d"
        Title="Phone Book" Height="450" Width="800">

    <Grid>
        <Grid.Resources>
            <DataTemplate DataType="{x:Type vms:ContactsListViewModel}">
                <views:ContactsListView/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type vms:AddNewContactViewModel}">
                <views:AddNewContactView/>
            </DataTemplate>
        </Grid.Resources>

        <ContentControl Content="{Binding CurrentViewModel}"/>
    </Grid>

</Window>
